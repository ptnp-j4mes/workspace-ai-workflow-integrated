NODE_ENV=development
DATABASE_URL="postgresql://workflow:workflow@localhost:5434/workspace_ai_workflow?schema=public"
PORT=3011
CORS_ORIGIN="http://localhost:3002"
API_PUBLIC_URL="http://localhost:3011"
FRONTEND_URL="http://localhost:3002"
# Optional: falls back to an insecure default when NODE_ENV=development.
# Required (boot throws) for any other NODE_ENV.
JWT_SECRET=
# Optional: Google OAuth login runs in demo mode when unset.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional: enables real Thai/Isan ASR via opentyphoon.ai for meeting transcription.
# Falls back to mock transcript when unset. Get a key at https://opentyphoon.ai/
TYPHOON_API_KEY=
