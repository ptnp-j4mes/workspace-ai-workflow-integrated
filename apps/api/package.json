    "prisma": "^6.11.1",
    "z-ai-web-dev-sdk": "^0.0.18"
  },
  "devDependencies": {
    "@types/node": "25.9.0",
    "bun-types": "^1.3.4",
    "typescript": "5.9.3"
  }
}
