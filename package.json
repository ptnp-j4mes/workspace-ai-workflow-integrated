{
  "name": "workspace-ai-workflow-integrated",
  "version": "0.2.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/api dev & bun run --cwd apps/web dev & wait",
    "build": "bun run --cwd apps/api db:generate && bun run --cwd apps/web build",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down -v",
    "lint": "npm run lint --workspace=apps/web",
    "workflow:validate": "node scripts/validate-ai-workflow.mjs",
    "clean:local": "node scripts/clean-local.mjs",
    "biccorp:validate": "node scripts/validate-biccorp-ai-workflow.mjs"
  }
}
