}

model MeetingBotAccount {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String
  status      String   @default("AVAILABLE") // AVAILABLE, BUSY, OFFLINE, ERROR
  lastUsedAt  DateTime?
