  transcriptionStartedAt DateTime?
  transcriptionEndedAt   DateTime?
  transcriptText       String?
  summaryStartedAt    DateTime?
  summaryEndedAt      DateTime?
  exportFormat        String?  // MARKDOWN, GOOGLE_DOCS, BOTH
