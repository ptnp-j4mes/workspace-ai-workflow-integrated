// ============================================================
// System Settings
// ============================================================

model SystemSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String   // JSON value
  valueType   String   @default("STRING") // STRING, NUMBER, BOOLEAN, JSON
  category    String   // GENERAL, AUTH, SMTP, GITHUB, AI, NOTIFICATION, WORKFLOW, SECURITY, APPEARANCE, DOCUMENT_NUMBER
  description String?
  isSecret    Boolean  @default(false)
  updatedById String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

// ============================================================
// Background Jobs / Scheduler
// ============================================================

model BackgroundJob {
  id           String   @id @default(cuid())
  jobKey       String   @unique
  name         String
  description  String?
  schedule     String?  // Cron expression or interval
  isEnabled    Boolean  @default(true)
  lastRunAt    DateTime?
  lastStatus   String?  // SUCCESS, FAILED, RUNNING
  nextRunAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  runs BackgroundJobRun[]

  @@map("background_jobs")
}

model BackgroundJobRun {
  id           String   @id @default(cuid())
  jobKey       String
  status       String   // RUNNING, SUCCESS, FAILED
  startedAt    DateTime @default(now())
  finishedAt   DateTime?
  result       String?  // JSON result summary
  errorMessage String?
  durationMs   Int?

  job BackgroundJob @relation(fields: [jobKey], references: [jobKey])

  @@map("background_job_runs")
