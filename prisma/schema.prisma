// ============================================================
// Enterprise AI Workflow Platform - Database Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// Auth & RBAC
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  password     String
  name         String
  avatarUrl    String?
  departmentId String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  phone        String?
  position     String?
  timezone     String   @default("Asia/Bangkok")
  locale       String   @default("th-TH")
  themePreference String?
  emailNotificationEnabled Boolean @default(true)
  inAppNotificationEnabled Boolean @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department    Department?       @relation(fields: [departmentId], references: [id])
  roles         UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  comments      RequestComment[]
  attachments   RequestAttachment[]
  assignedBAs   Request[]         @relation("AssignedBA")
  assignedDevs  Request[]         @relation("AssignedDev")
  assignedQAs   Request[]         @relation("AssignedQA")
  workItems     WorkItemAssignment[]
  actionItems   MeetingActionItem[]
  notifications Notification[]
  promptRuns    AiPromptRun[]
  createdProjects    Project[]    @relation("ProjectCreator")
  projectMemberships ProjectMember[]
  createdRequests    Request[]    @relation("RequestCreator")
  meetingParticipants MeetingParticipant[]
  testResults    UatTestResult[]
  bugReports     BugReport[]     @relation("BugReporter")
  notificationPreferences NotificationPreference[]
  approvalActions ApprovalAction[]
  mitAssignees   MitStepAssignment[]
  riskCreators   ProjectRisk[]   @relation("RiskCreator")
  issueCreators  ProjectIssue[]  @relation("IssueCreator")
  decisionCreators ProjectDecision[] @relation("DecisionCreator")
  githubConnections GithubConnection[]
  documentNumbers DocumentNumber[] @relation("DocumentNumberGenerator")
  voidedDocuments DocumentNumber[] @relation("DocumentNumberVoider")
  googleOAuthTokens GoogleOAuthToken[]
  calendarEvents    GoogleCalendarEvent[]
  activityDailies      ActivityDaily[]
  approvedActivityDailies ActivityDaily[] @relation("ActivityDailyApprover")
  platformRequests       PlatformRequest[] @relation("PlatformRequestRequester")
  platformApprovals      PlatformRequestApproval[]
  reviewedDivisionPlatforms  PlatformRequest[] @relation("PlatformRequestDivisionHead")
  reviewedSDPlatforms        PlatformRequest[] @relation("PlatformRequestSDManager")
  projectVersions            ProjectVersion[]  @relation("ProjectVersionCreator")
  vaultNodes                 VaultNode[]       @relation("VaultNodeCreator")
  vaultAttachments           VaultAttachment[]

  @@map("users")
}

model Role {
  id          String @id @default(cuid())
  key         String @unique
  name        String
  description String?
  users       UserRole[]
  permissions RolePermission[]
  menuPermissions MenuPermission[]

  @@map("roles")
}

model Permission {
  id          String @id @default(cuid())
  key         String @unique
  name        String
  module      String
  description String?
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  id     String @id @default(cuid())
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@map("user_roles")
}

model RolePermission {
  id           String @id @default(cuid())
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  code        String   @unique
  type        String   @default("SECTION") // DIVISION (ฝ่าย) or SECTION (แผนก)
  description String?  // e.g. "SD-ฝ่ายวิเคราะห์และพัฒนาซอฟต์แวร์"
  parentId    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Department?  @relation("DepartmentTree", fields: [parentId], references: [id])
  children Department[] @relation("DepartmentTree")
  users    User[]
  jobPositions JobPosition[]
  platformRequests PlatformRequest[]

  @@map("departments")
}

model JobPosition {
  id           String   @id @default(cuid())
  name         String   @unique
  code         String   @unique
  level        String?  // e.g. J1, J2, M1, M2, D1, EXE
  category     String?  // e.g. ENGINEERING, BUSINESS, MANAGEMENT, SUPPORT
  departmentId String?  // Optional link to a specific department/section
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department Department? @relation(fields: [departmentId], references: [id])

  @@map("job_positions")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entity      String
  entityId    String?
  aitNo       String?
  oldValue    String?
  newValue    String?
  entityType  String?
  userAgent   String?
  ip          String?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

// ============================================================
// Project
// ============================================================

model Project {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  status      String   @default("ACTIVE") // ACTIVE, ON_HOLD, COMPLETED, ARCHIVED
  startDate   DateTime?
  endDate     DateTime?
  aitNo       String?  // AIT Project Document Number
  healthScore Float?   // 0-100 calculated health score
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy      User             @relation("ProjectCreator", fields: [createdById], references: [id])
  members        ProjectMember[]
  requests       Request[]
  meetings       Meeting[]
  uatCycles      UatCycle[]
  maintenanceAgs MaintenanceAgreement[]
  githubRepos    ProjectGithubRepository[]
  risks          ProjectRisk[]
  issues         ProjectIssue[]
  decisions      ProjectDecision[]
  calendarEvents GoogleCalendarEvent[]
  platformRequest PlatformRequest?
  currentVersion Int      @default(1)
  versions       ProjectVersion[]
  vaultNodes     VaultNode[]
  attachments    VaultAttachment[]

  @@map("projects")
}

model ProjectMember {
  id        String @id @default(cuid())
  projectId String
  userId    String
  role      String // PROJECT_MANAGER, LEAD, MEMBER

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectVersion {
  id          String   @id @default(cuid())
  projectId   String
  version     Int
  name        String
  description String?
  status      String
  startDate   DateTime?
  endDate     DateTime?
  aitNo       String?
  healthScore Float?
  changeLog   String?
  changeType  String   @default("UPDATE") // CREATE, UPDATE, STATUS_CHANGE, RESTORE
  snapshot    String   // JSON snapshot of all project fields at this version
  createdById String
  createdAt   DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ProjectVersionCreator", fields: [createdById], references: [id])

  @@unique([projectId, version])
  @@map("project_versions")
}

// ============================================================
// Project Risk / Issue / Decision
// ============================================================

model ProjectRisk {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  probability String   @default("MEDIUM") // LOW, MEDIUM, HIGH
  impact      String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  mitigation  String?
  status      String   @default("IDENTIFIED") // IDENTIFIED, ANALYZING, MITIGATING, RESOLVED, ACCEPTED
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User?   @relation("RiskCreator", fields: [ownerId], references: [id])

  @@map("project_risks")
}

model ProjectIssue {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  severity    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  resolution  String?
  ownerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User?   @relation("IssueCreator", fields: [ownerId], references: [id])

  @@map("project_issues")
}

model ProjectDecision {
  id          String   @id @default(cuid())
  projectId   String
  title       String
  description String?
  decision    String?
  rationale   String?
  alternatives String?  // JSON array
  status      String   @default("PROPOSED") // PROPOSED, ACCEPTED, REJECTED, DEFERRED
  decidedById String?
  decidedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  decidedBy User?  @relation("DecisionCreator", fields: [decidedById], references: [id])

  @@map("project_decisions")
}

// ============================================================
// Request
// ============================================================

model Request {
  id             String   @id @default(cuid())
  code           String   @unique
  title          String
  description    String
  type           String   // FEATURE, BUG, CHANGE, SUPPORT, QUESTION, INCIDENT
  priority       String   @default("MEDIUM") // LOW, MEDIUM, HIGH, URGENT
  status         String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED, REJECTED, ASSIGNED, IN_DEVELOPMENT, QA, UAT, COMPLETED, CLOSED
  projectId      String?
  affectedSystem String?
  businessImpact String?
  acceptanceCriteria String?
  assignedBAId   String?
  assignedDevId  String?
  assignedQAId   String?
  createdById    String
  aitNo          String?  // AIT Request Document Number
  dueDate        DateTime?
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  project       Project?        @relation(fields: [projectId], references: [id])
  createdBy     User            @relation("RequestCreator", fields: [createdById], references: [id])
  assignedBA    User?           @relation("AssignedBA", fields: [assignedBAId], references: [id])
  assignedDev   User?           @relation("AssignedDev", fields: [assignedDevId], references: [id])
  assignedQA    User?           @relation("AssignedQA", fields: [assignedQAId], references: [id])
  comments      RequestComment[]
  attachments   RequestAttachment[]
  statusHistory RequestStatusHistory[]
  aiDrafts      RequestAiDraft[]
  workItems     WorkItem[]
  bugReports    BugReport[]
  changeRequests ChangeRequest[]

  @@map("requests")
}

model RequestComment {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("request_comments")
}

model RequestAttachment {
  id        String   @id @default(cuid())
  requestId String
  userId    String
  fileName  String
  fileUrl   String
  fileSize  Int?
  mimeType  String?
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@map("request_attachments")
}

model RequestStatusHistory {
  id        String   @id @default(cuid())
  requestId String
  fromStatus String?
  toStatus  String
  comment   String?
  changedById String?
  createdAt DateTime @default(now())

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("request_status_history")
}

model RequestAiDraft {
  id          String   @id @default(cuid())
  requestId   String?
  suggestedType    String?
  suggestedTitle   String?
  suggestedDescription String?
  suggestedPriority String?
  missingFields    String?  // JSON array of field names
  followUpQuestions String? // JSON array of questions
  confidence       Float?
  rawData          String?  // JSON
  createdAt        DateTime @default(now())

  request Request? @relation(fields: [requestId], references: [id])

  @@map("request_ai_drafts")
}

// ============================================================
// Workflow Engine
// ============================================================

model WorkflowDefinition {
  id          String   @id @default(cuid())
  name        String
  description String?
  entityType  String   // REQUEST, WORK_ITEM, etc.
  isActive    Boolean  @default(true)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps       WorkflowStep[]
  transitions WorkflowTransition[]
  instances   WorkflowInstance[]

  @@map("workflow_definitions")
}

model WorkflowStep {
  id                String   @id @default(cuid())
  workflowDefId     String
  name              String
  stepKey           String
  description       String?
  allowedRoles      String?  // JSON array of role keys
  slaHours          Int?
  autoAssignToRole  String?
  isInitial         Boolean  @default(false)
  isFinal           Boolean  @default(false)
  order             Int      @default(0)
  createdAt         DateTime @default(now())

  workflowDef  WorkflowDefinition @relation(fields: [workflowDefId], references: [id], onDelete: Cascade)
  fromTransitions WorkflowTransition[] @relation("FromStep")
  toTransitions   WorkflowTransition[] @relation("ToStep")

  @@unique([workflowDefId, stepKey])
  @@map("workflow_steps")
}

model WorkflowTransition {
  id            String   @id @default(cuid())
  workflowDefId String
  fromStepId    String
  toStepId      String
  action        String
  allowedRoles  String?  // JSON array
  requiresComment Boolean @default(false)
  autoActions   String?  // JSON
  createdAt     DateTime @default(now())

  workflowDef WorkflowDefinition @relation(fields: [workflowDefId], references: [id], onDelete: Cascade)
  fromStep    WorkflowStep       @relation("FromStep", fields: [fromStepId], references: [id], onDelete: Cascade)
  toStep      WorkflowStep       @relation("ToStep", fields: [toStepId], references: [id], onDelete: Cascade)

  @@map("workflow_transitions")
}

model WorkflowInstance {
  id              String   @id @default(cuid())
  workflowDefId   String
  entityId        String
  entityType      String
  currentStepId   String?
  status          String   @default("ACTIVE") // ACTIVE, COMPLETED, CANCELLED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflowDef WorkflowDefinition @relation(fields: [workflowDefId], references: [id])
  events      WorkflowEvent[]

  @@map("workflow_instances")
}

model WorkflowEvent {
  id                String   @id @default(cuid())
  instanceId        String
  fromStep          String?
  toStep            String
  action            String
  comment           String?
  performedById     String?
  aiRecommendation  String?  // JSON
  createdAt         DateTime @default(now())

  instance WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  @@map("workflow_events")
}

// ============================================================
// Work Items / MIT (Managed Item Tracking)
// ============================================================

model WorkItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  requestId   String?
  projectId   String?
  status      String   @default("CREATED") // CREATED, ASSIGNED, ACCEPTED, IN_PROGRESS, SUBMITTED, DEPLOYED, RETURNED, REJECTED
  currentStep String?  // BA, DEV, QA, UAT, MA
  priority    String   @default("MEDIUM")
  aitNo       String?  // AIT MIT Document Number
  dueDate          DateTime?
  estimatedManDays Float?    @default(0)
  spentManDays     Float?    @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  request     Request?           @relation(fields: [requestId], references: [id])
  assignments WorkItemAssignment[]
  handoffs    WorkItemHandoff[]
  statusHistory WorkItemStatusHistory[]
  mitStepAssignments MitStepAssignment[]

  @@map("work_items")
}

model WorkItemAssignment {
  id        String   @id @default(cuid())
  workItemId String
  userId    String
  role      String   // BA, DEVELOPER, QA, FULLSTACK
  isActive  Boolean  @default(true)
  assignedAt DateTime @default(now())
  acceptedAt DateTime?

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id])

  @@map("work_item_assignments")
}

model WorkItemHandoff {
  id           String   @id @default(cuid())
  workItemId   String
  fromUserId   String?
  toUserId     String?
  fromRole     String?
  toRole       String?
  handoffNote  String?
  aiGeneratedNote String?
  status       String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  createdAt    DateTime @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@map("work_item_handoffs")
}

model WorkItemStatusHistory {
  id          String   @id @default(cuid())
  workItemId  String
  fromStatus  String?
  toStatus    String
  comment     String?
  changedById String?
  createdAt   DateTime @default(now())

  workItem WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)

  @@map("work_item_status_history")
}

// ============================================================
// MIT Step Assignment (Role-based eligibility tracking)
// ============================================================

model MitStepAssignment {
  id          String   @id @default(cuid())
  workItemId  String
  step        String   // BA, DEV, QA, UAT, MA
  assigneeId  String?
  status      String   @default("PENDING") // PENDING, ASSIGNED, ACCEPTED, REJECTED, RETURNED, SUBMITTED, DEPLOYED
  assignedById String?
  assignedAt  DateTime?
  acceptedAt  DateTime?
  submittedAt DateTime?
  deployedAt  DateTime?
  rejectedAt  DateTime?
  returnedAt  DateTime?
  rejectionReason String?
  returnReason    String?
  estimatedManDays Float?   @default(0)
  spentManDays     Float?   @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workItem   WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  assignee   User?    @relation(fields: [assigneeId], references: [id])

  @@map("mit_step_assignments")
}

// ============================================================
// UAT
// ============================================================

model UatCycle {
  id          String   @id @default(cuid())
  projectId   String
  requestId   String?
  name        String
  description String?
  status      String   @default("PLANNED") // PLANNED, IN_PROGRESS, COMPLETED, FAILED
  aitNo       String?  // AIT UAT Document Number
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project       @relation(fields: [projectId], references: [id])
  testCases UatTestCase[]

  @@map("uat_cycles")
}

model UatTestCase {
  id            String   @id @default(cuid())
  uatCycleId    String
  title         String
  precondition  String?
  steps         String   // JSON array
  expectedResult String
  priority      String   @default("MEDIUM")
  type          String   @default("FUNCTIONAL") // FUNCTIONAL, REGRESSION, NEGATIVE, EDGE_CASE
  aiGenerated   Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  uatCycle    UatCycle        @relation(fields: [uatCycleId], references: [id], onDelete: Cascade)
  testResults UatTestResult[]

  @@map("uat_test_cases")
}

model UatTestResult {
  id          String   @id @default(cuid())
  testCaseId  String
  testerId    String
  status      String   // PASSED, FAILED, BLOCKED, SKIPPED
  actualResult String?
  comments    String?
  testedAt    DateTime @default(now())

  testCase UatTestCase @relation(fields: [testCaseId], references: [id], onDelete: Cascade)
  tester   User        @relation(fields: [testerId], references: [id])

  @@map("uat_test_results")
}

// ============================================================
// Bug & Change
// ============================================================

model BugReport {
  id               String   @id @default(cuid())
  requestId        String?
  projectId        String?
  title            String
  description      String
  severity         String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  actualResult     String?
  expectedResult   String?
  reproductionSteps String?
  rootCause        String?
  fixVersion       String?
  status           String   @default("OPEN") // OPEN, INVESTIGATING, FIXING, FIXED, VERIFIED, CLOSED
  aitNo            String?  // AIT BUG Document Number
  reportedById     String
  aiRca            String?  // JSON
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  request       Request?  @relation(fields: [requestId], references: [id])
  reportedBy    User      @relation("BugReporter", fields: [reportedById], references: [id])

  @@map("bug_reports")
}

model ChangeRequest {
  id              String   @id @default(cuid())
  requestId       String?
  projectId       String?
  title           String
  description     String
  category        String? // ENHANCEMENT, MODIFICATION, REMOVAL, MIGRATION
  impactLevel     String? @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  isApproved      Boolean @default(false)
  aitNo           String?  // AIT CHG Document Number
  status          String   @default("DRAFT") // DRAFT, PENDING_APPROVAL, APPROVED, REJECTED, IMPLEMENTING, COMPLETED
  impactAnalysis  String? // JSON
  aiImpactAnalysis String? // JSON
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  request Request? @relation(fields: [requestId], references: [id])

  @@map("change_requests")
}

// ============================================================
// Maintenance
// ============================================================

model MaintenanceAgreement {
  id          String   @id @default(cuid())
  projectId   String
  type        String   // STANDARD, PREMIUM, CUSTOM
  startDate   DateTime
  endDate     DateTime
  status      String   @default("ACTIVE") // ACTIVE, EXPIRED, RENEWED, CANCELLED
  aitNo       String?  // AIT MA Document Number
  slaDetails  String?  // JSON
  coverage    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project      Project                @relation(fields: [projectId], references: [id])
  supportCases MaintenanceSupportCase[]

  @@map("maintenance_agreements")
}

model MaintenanceSupportCase {
  id                   String   @id @default(cuid())
  maintenanceAgId      String
  title                String
  description          String
  priority             String   @default("MEDIUM")
  status               String   @default("OPEN")
  resolvedAt           DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  maintenanceAg MaintenanceAgreement @relation(fields: [maintenanceAgId], references: [id], onDelete: Cascade)

  @@map("maintenance_support_cases")
}

// ============================================================
// Meeting
// ============================================================

model Meeting {
  id          String   @id @default(cuid())
  projectId   String?
  requestId   String?
  title       String
  description String?
  meetingUrl  String?
  scheduledAt DateTime?
  endedAt     DateTime?
  status      String   @default("SCHEDULED") // SCHEDULED, IN_PROGRESS, COMPLETED, CANCELLED
  botStatus   String?  // IDLE, JOINING, ACTIVE, LEAVING, ERROR
  botAccountId String?
  recordingStatus String? // NONE, RECORDING, COMPLETED, FAILED
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project      Project?             @relation(fields: [projectId], references: [id])
  participants MeetingParticipant[]
  transcripts  MeetingTranscript[]
  summaries    MeetingSummary[]
  actionItems  MeetingActionItem[]
  botSessions  MeetingBotSession[]
  recordings   MeetingRecording[]
  calendarEvent GoogleCalendarEvent?

  @@map("meetings")
}

model MeetingParticipant {
  id        String @id @default(cuid())
  meetingId String
  userId    String?
  name      String
  email     String?
  role      String? // ORGANIZER, ATTENDEE

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id])

  @@map("meeting_participants")
}

model MeetingTranscript {
  id        String   @id @default(cuid())
  meetingId String
  content   String
  format    String   @default("TEXT") // TEXT, SRT, VTT
  duration  Int?
  createdAt DateTime @default(now())

