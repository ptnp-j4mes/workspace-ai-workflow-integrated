// ============================================================
// AI Prompt Management
// ============================================================

model AiPrompt {
  id          String   @id @default(cuid())
  promptKey   String   @unique
  title       String
  description String?
  category    String   // MEETING, INTAKE, WORKFLOW, UAT, BUG, CHANGE, HANDOFF, DASHBOARD, NOTIFICATION
  provider    String   @default("default")
  model       String   @default("default")
  status      String   @default("DRAFT") // DRAFT, ACTIVE, DEPRECATED
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  versions    AiPromptVersion[]
  testCases   AiPromptTestCase[]
  runs        AiPromptRun[]

  @@map("ai_prompts")
}

model AiPromptVersion {
  id                String   @id @default(cuid())
  promptId          String
  version           Int
  systemPrompt      String
  userPromptTemplate String
  inputSchema       String?  // JSON Schema
  outputSchema      String?  // JSON Schema
  temperature       Float    @default(0.7)
  maxTokens         Int      @default(4096)
  changeLog         String?
  status            String   @default("DRAFT") // DRAFT, ACTIVE, DEPRECATED
  activatedAt       DateTime?
  activatedById     String?
  createdAt         DateTime @default(now())

  prompt    AiPrompt     @relation(fields: [promptId], references: [id], onDelete: Cascade)
  runs      AiPromptRun[]

  @@unique([promptId, version])
  @@map("ai_prompt_versions")
}

model AiPromptTestCase {
  id          String   @id @default(cuid())
  promptId    String
  name        String
  inputVars   String   // JSON
  expectedOutput String?
  expectedContains String? // JSON array of strings that should be in output
  description String?
  createdAt   DateTime @default(now())

  prompt AiPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@map("ai_prompt_test_cases")
}

model AiPromptRun {
  id               String   @id @default(cuid())
  promptId         String
  promptVersionId  String
  inputVars        String?  // JSON
  rawOutput        String?
  parsedOutput     String?  // JSON
  isValid          Boolean?
  validationErrors String?
  isTestRun        Boolean  @default(false)
  testPassed       Boolean?
  tokenUsage       String?  // JSON { input, output, total }
  latencyMs        Int?
  costEstimate     Float?
  error            String?
  runById          String?
  createdAt        DateTime @default(now())

  prompt        AiPrompt       @relation(fields: [promptId], references: [id], onDelete: Cascade)
  promptVersion AiPromptVersion @relation(fields: [promptVersionId], references: [id])
  runBy         User?          @relation(fields: [runById], references: [id])

  @@map("ai_prompt_runs")
}

model AiProviderConfig {
  id          String   @id @default(cuid())
  provider    String   @unique
  name        String
  apiKeyEnc   String?  // Encrypted API key
  baseUrl     String?
  models      String?  // JSON array of model IDs
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ai_provider_configs")
}

model AiGeneratedArtifact {
  id          String   @id @default(cuid())
  type        String   // SUMMARY, DRAFT, TEST_CASE, RCA, HANDOFF_NOTE, INSIGHT, ACTION_ITEMS
  sourceId    String?
  sourceType  String?
  content     String
  promptRunId String?
  createdAt   DateTime @default(now())

  @@map("ai_generated_artifacts")
}

// ============================================================
// Notifications (Enhanced)
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // INFO, WARNING, ERROR, ACTION_REQUIRED
  eventKey  String?  // e.g. REQUEST_SUBMITTED, MIT_ASSIGNED
  entityType String? // REQUEST, PROJECT, MIT, etc.
