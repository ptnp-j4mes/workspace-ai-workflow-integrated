  @@map("notification_preferences")
}

model NotificationDelivery {
  id             String   @id @default(cuid())
  notificationId String
  channel        String   // IN_APP, EMAIL
  status         String   @default("PENDING") // PENDING, SENT, FAILED
  deliveredAt    DateTime?
  errorMessage   String?
  createdAt      DateTime @default(now())

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@map("notification_deliveries")
}

// ============================================================
// AIT Document Number Management
// ============================================================

model DocumentNumberSequence {
  id             String   @id @default(cuid())
  documentType   String   @unique // REQUEST, PROJECT, MIT, UAT, BUG, CHANGE, APPROVAL, MA
  prefix         String   // AIT-REQ, AIT-PRJ, etc.
  year           Int      @default(2026)
  currentNumber  Int      @default(0)
  paddingLength  Int      @default(6)
  formatTemplate String   @default("AIT-{PREFIX}-{YEAR}-{NUMBER}") 
  resetPolicy    String   @default("YEARLY") // YEARLY, MONTHLY, NEVER
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("document_number_sequences")
}

model DocumentNumber {
  id            String   @id @default(cuid())
  documentNo    String   @unique // e.g. AIT-REQ-2026-000001
  documentType  String   // REQUEST, PROJECT, MIT, UAT, BUG, CHANGE, APPROVAL, MA
  entityType    String?  // The entity type this number is assigned to
  entityId      String?  // The entity ID this number is assigned to
  status        String   @default("ACTIVE") // ACTIVE, VOID, RESERVED
  generatedById String?
  generatedAt   DateTime @default(now())
  voidedById    String?
  voidedAt      DateTime?
  voidReason    String?
  metadata      String?  // JSON
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  generator User? @relation("DocumentNumberGenerator", fields: [generatedById], references: [id])
  voidedBy  User? @relation("DocumentNumberVoider", fields: [voidedById], references: [id])

  @@map("document_numbers")
}

// ============================================================
// Approval Workflow (Configurable multi-step)
// ============================================================

model ApprovalWorkflow {
  id          String   @id @default(cuid())
  workflowKey String   @unique
  entityType  String   // REQUEST, PROJECT, CHANGE, UAT_SIGNOFF
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps      ApprovalStep[]
  instances  ApprovalInstance[]

  @@map("approval_workflows")
}

model ApprovalStep {
  id              String   @id @default(cuid())
  workflowId      String
  stepOrder       Int
  stepName        String
  approverRole    String?  // Role key(s) that can approve at this step
  approverUserId  String?  // Specific user override
  requiredAction  String   @default("APPROVE") // APPROVE, REVIEW, SIGNOFF
  isRequired      Boolean  @default(true)
  slaHours        Int?
  createdAt       DateTime @default(now())

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actions  ApprovalAction[]

  @@map("approval_steps")
}

model ApprovalInstance {
  id            String   @id @default(cuid())
  aitNo         String?  // AIT APR Document Number
  workflowId    String
  entityType    String
  entityId      String
  currentStepId String?
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED, CANCELLED
  requestedById String?
  requestedAt   DateTime @default(now())
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workflow ApprovalWorkflow @relation(fields: [workflowId], references: [id])
  actions  ApprovalAction[]

  @@map("approval_instances")
}

model ApprovalAction {
  id          String   @id @default(cuid())
  instanceId  String
  stepId      String
  actorUserId String
  action      String   // APPROVE, REJECT, COMMENT, DELEGATE
  comment     String?
  createdAt   DateTime @default(now())

  instance ApprovalInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)
  step     ApprovalStep     @relation(fields: [stepId], references: [id], onDelete: Cascade)
  actor    User             @relation(fields: [actorUserId], references: [id])

  @@map("approval_actions")
}

model ApprovalDelegation {
  id            String   @id @default(cuid())
  fromUserId    String
  toUserId      String
  entityType    String? // If null, delegates all types
  startDate     DateTime
  endDate       DateTime?
  reason        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  @@map("approval_delegations")
}

// ============================================================
// GitHub Integration
// ============================================================

model GithubConnection {
  id              String   @id @default(cuid())
  connectionName  String
  authType        String   @default("TOKEN") // TOKEN, GITHUB_APP
  tokenEncrypted  String?  // Encrypted token or secret ref
  owner           String
  isActive        Boolean  @default(true)
  lastSyncAt      DateTime?
  createdById     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  creator     User               @relation(fields: [createdById], references: [id])
  repositories GithubRepository[]

  @@map("github_connections")
}

model GithubRepository {
  id             String   @id @default(cuid())
  connectionId   String
  owner          String
  repo           String
  fullName       String   // owner/repo
  defaultBranch  String   @default("main")
  visibility     String   @default("private") // public, private, internal
  lastCommitSha  String?
  lastSyncedAt   DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  connection     GithubConnection     @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  projectRepos   ProjectGithubRepository[]
  commits        GithubCommit[]

  @@map("github_repositories")
}

model ProjectGithubRepository {
  id           String   @id @default(cuid())
  projectId    String
  repositoryId String
  branch       String   @default("main")
  pathFilter   String?  // Optional path filter for monorepos
  isPrimary    Boolean  @default(false)
  createdAt    DateTime @default(now())

  project    Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  repository GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@unique([projectId, repositoryId])
  @@map("project_github_repositories")
}

model GithubCommit {
  id             String   @id @default(cuid())
  repositoryId   String
  projectId      String?
  sha            String
  message        String
  authorName     String
  authorEmail    String?
  authorDate     DateTime
  committerName  String?
  committerDate  DateTime?
  branch         String?
  additions      Int?
  deletions      Int?
  changedFiles   Int?
  url            String?
  rawPayload     String?  // JSON
  createdAt      DateTime @default(now())

  repository GithubRepository @relation(fields: [repositoryId], references: [id], onDelete: Cascade)

  @@map("github_commits")
}

model GithubCommitDailySummary {
  id                 String   @id @default(cuid())
  projectId          String
  repositoryId       String?
  summaryDate        DateTime
  totalCommits       Int      @default(0)
  authorsJson        String?  // JSON array of authors
  changedFilesCount  Int      @default(0)
  aiSummaryMarkdown  String?
  riskNotesJson      String?  // JSON array
  generatedBy        String   @default("RULE") // RULE, AI
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([projectId, repositoryId, summaryDate])
  @@map("github_commit_daily_summaries")
}

model GithubSyncLog {
  id            String   @id @default(cuid())
  connectionId  String
  repositoryId  String?
  projectId     String?
  status        String   // SUCCESS, FAILED, PARTIAL
  startedAt     DateTime @default(now())
  finishedAt    DateTime?
  message       String?
  errorMessage  String?
  metadata      String?  // JSON

  @@map("github_sync_logs")
}

// ============================================================
// SMTP / Email
// ============================================================

model SmtpSetting {
  id               String   @id @default(cuid())
  name             String
  host             String
  port             Int      @default(587)
  secure           Boolean  @default(false)
  username         String
  passwordEncrypted String? // Encrypted or secretRef
  fromEmail        String
  fromName         String?
  isDefault        Boolean  @default(false)
  isActive         Boolean  @default(true)
  lastTestAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

