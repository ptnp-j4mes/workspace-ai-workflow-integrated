// ============================================================
// Google OAuth & Calendar Integration
// ============================================================

model GoogleOAuthToken {
  id              String   @id @default(cuid())
  userId          String
  purpose         String   @default("PERSONAL") // PERSONAL, BOT — whether this is a user's personal Google account or a bot account
  googleEmail     String
  accessToken     String   // Encrypted
  refreshToken    String?  // Encrypted
  tokenExpiry     DateTime?
  scope           String?  // OAuth scopes granted
  isActive        Boolean  @default(true)
  lastRefreshedAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  botAccount    MeetingBotAccount?
  calendarEvents GoogleCalendarEvent[]

  @@unique([userId, googleEmail])
  @@map("google_oauth_tokens")
}

model GoogleCalendarEvent {
  id              String   @id @default(cuid())
  googleEventId   String   @unique // Google Calendar event ID
  userId          String
  oauthTokenId    String
  projectId       String?
  meetingId       String?  @unique // Linked meeting if matched
  title           String
  description     String?
  meetingUrl      String?  // Google Meet URL
  location        String?
  organizerEmail  String?
  startAt         DateTime
  endAt           DateTime
  status          String   @default("CONFIRMED") // CONFIRMED, TENTATIVE, CANCELLED
  attendees       String?  // JSON array of {email, name, responseStatus}
  isRecurring     Boolean  @default(false)
  recurrenceRule  String?
  syncedAt        DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  oauthToken  GoogleOAuthToken @relation(fields: [oauthTokenId], references: [id], onDelete: Cascade)
  project     Project?         @relation(fields: [projectId], references: [id])
  meeting     Meeting?         @relation(fields: [meetingId], references: [id])

  @@map("google_calendar_events")
}

// ============================================================
// Meeting Recording (Audio file tracking)
// ============================================================

model MeetingRecording {
  id              String   @id @default(cuid())
  meetingId       String
  botSessionId    String?
  filePath        String   // Path to saved audio file
  fileName        String
  fileSizeBytes   Int?
  durationSeconds Int?
  format          String   @default("wav") // wav, mp3, webm
  sampleRate      Int?
  channels        Int      @default(1)
  status          String   @default("RECORDING") // RECORDING, COMPLETED, FAILED, DELETED
  startedAt       DateTime?
  endedAt         DateTime?
  transcriptionStatus String? @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  transcriptionText   String? // Raw transcript text (also saved to MeetingTranscript)
  transcriptionId     String? // Link to MeetingTranscript record
  summaryStatus       String? @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED, FAILED
  summaryId           String? // Link to MeetingSummary record
  exportStatus        String? @default("PENDING") // PENDING, COMPLETED, FAILED
  exportFormat        String? // MARKDOWN, GOOGLE_DOCS, BOTH
  exportFilePath      String?
  exportDocsUrl       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  meeting     Meeting          @relation(fields: [meetingId], references: [id], onDelete: Cascade)

  @@map("meeting_recordings")
}

// ============================================================
// Activity Daily & AI Usage KPI
// ============================================================

model ActivityDaily {
  id                  String   @id @default(cuid())
  userId              String
  date                DateTime // The work date
  totalWorkHours      Float    @default(8) // Total work hours in the day (e.g., 8)
  aiUsageHours        Float    @default(0) // Hours using AI tools
  aiUsagePercentage   Float    @default(0) // Calculated: aiUsageHours / totalWorkHours * 100
  kpiTargetPercentage Float    @default(25) // AI usage KPI target % (25% = 2hr AI out of 8hr)
  kpiMet              Boolean  @default(false) // Whether AI usage KPI target was met
  summary             String?  // Text summary of the day's work
  commitSummary       String?  // Auto-generated from git commits
  commitCount         Int      @default(0) // Number of commits that day
  projectEntries      String?  // JSON array of {projectId, projectName, hours, aiHours, tasks, commitCount, commitMessages[]}
  status              String   @default("DRAFT") // DRAFT, SUBMITTED, APPROVED
  approvedById        String?
  approvedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user        User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy  User?  @relation("ActivityDailyApprover", fields: [approvedById], references: [id])

  @@unique([userId, date])
  @@map("activity_dailies")
}

// ============================================================
// Menu Management (Database-driven navigation)
// ============================================================

model Menu {
  id                 String   @id @default(cuid())
  key                String   @unique // e.g. 'dashboard', 'projects', 'admin-users'
  label              String   // Display name (English)
  labelTh            String?  // Display name (Thai)
  icon               String   // Lucide icon name, e.g. 'LayoutDashboard', 'FolderKanban'
  view               String   // The view key to navigate to
  parentId           String?  // Self-relation for lv2 menus under lv1
  level              Int      @default(1) // 1 = top level, 2 = child
  sortOrder          Int      @default(0) // For drag-and-drop ordering
  isVisible          Boolean  @default(true) // Toggle visibility
  isExpanded         Boolean  @default(false) // Whether lv1 starts expanded showing lv2 children
  requiredPermission String?  // Permission key required to see this menu
  badge              String?  // Optional badge text like count
  badgeVariant       String?  @default("default") // Badge variant: default, destructive, outline, secondary
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  parent   Menu?  @relation("MenuTree", fields: [parentId], references: [id])
  children Menu[] @relation("MenuTree")
  menuPermissions MenuPermission[]

  @@map("menus")
}

model MenuPermission {
  id     String @id @default(cuid())
  menuId String
  roleId String

  menu Menu @relation(fields: [menuId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([menuId, roleId])
  @@map("menu_permissions")
}

// ============================================================
// Platform Request (User requests to create Program/Platform)
// ============================================================

model PlatformRequest {
  id                String   @id @default(cuid())
  requestNo         String   @unique // Generated run number, e.g. AIT-PLT-2605-001
  name              String   // Platform/Program name
  description       String   // Detailed description
  objective         String?  // Business objective / purpose
  targetUsers       String?  // Who will use this platform
  expectedTimeline  String?  // Expected completion timeline, e.g. "Q3 2026"
  priority          String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  status            String   @default("PENDING") // PENDING, DIVISION_APPROVED, APPROVED, REJECTED, CANCELLED, LINKED
  requesterId       String   // User who requested
  departmentId      String?  // Department of requester (denormalized for quick access)
  divisionHeadId    String?  // Auto-resolved: head of requester's division
  sdManagerId       String?  // SD manager who does final approval
  projectId         String?  @unique // Linked project after approval
  rejectionReason   String?  // Reason if rejected
  approvedAt        DateTime? // Final approval timestamp
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  requester    User                     @relation("PlatformRequestRequester", fields: [requesterId], references: [id])
  department   Department?              @relation(fields: [departmentId], references: [id])
  divisionHead User?                    @relation("PlatformRequestDivisionHead", fields: [divisionHeadId], references: [id])
  sdManager    User?                    @relation("PlatformRequestSDManager", fields: [sdManagerId], references: [id])
  project      Project?                 @relation(fields: [projectId], references: [id])
  approvals    PlatformRequestApproval[]

  @@map("platform_requests")
}

model PlatformRequestApproval {
  id                String   @id @default(cuid())
  platformRequestId String
  step              String   // DIVISION_HEAD, SD_MANAGER
  status            String   @default("PENDING") // PENDING, APPROVED, REJECTED
  approverId        String
  comment           String?
  actedAt           DateTime?
  createdAt         DateTime @default(now())

  platformRequest PlatformRequest @relation(fields: [platformRequestId], references: [id], onDelete: Cascade)
  approver        User            @relation(fields: [approverId], references: [id])

  @@unique([platformRequestId, step])
  @@map("platform_request_approvals")
}

// ============================================================
// Memory Vault (Obsidian-style Knowledge Base)
// ============================================================

model VaultNode {
  id          String   @id @default(cuid())
  projectId   String
  parentId    String?  // null = root level
  name        String   // File/folder name (e.g. "01-Requirements.md", "Architecture")
  type        String   @default("NOTE") // NOTE, FOLDER, SOLUTION, INDEX, DAILY_NOTE, TEMPLATE, CANVAS
  content     String?  // Markdown content (null for folders)
  frontmatter String?  // JSON: YAML frontmatter as key-value pairs
  tags        String?  // JSON array: ["requirement", "architecture"]
  sortOrder   Int      @default(0)
  isPinned    Boolean  @default(false)
  isExpanded  Boolean  @default(false) // for folders: default expanded state
  icon        String?  // Obsidian icon name or emoji
  color       String?  // Node color for graph view
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project   Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent    VaultNode?  @relation("VaultTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  VaultNode[] @relation("VaultTree")
  outgoing  VaultLink[] @relation("OutgoingLinks")
  incoming  VaultLink[] @relation("IncomingLinks")
  creator      User?            @relation("VaultNodeCreator", fields: [createdById], references: [id])
  attachments VaultAttachment[]

  @@map("vault_nodes")
}

model VaultLink {
  id         String   @id @default(cuid())
  sourceId   String
  targetId   String
  label      String?  // Optional link label/context
  linkType   String   @default("REFERENCE") // REFERENCE, DEPENDS_ON, RELATED, DERIVED_FROM, IMPLEMENTS
  createdAt  DateTime @default(now())

  source VaultNode @relation("OutgoingLinks", fields: [sourceId], references: [id], onDelete: Cascade)
  target VaultNode @relation("IncomingLinks", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, linkType])
  @@map("vault_links")
}

// ============================================================
// Vault Attachments (File Upload)
// ============================================================

model VaultAttachment {
  id          String   @id @default(cuid())
  nodeId      String?  // null = project-level attachment, not linked to specific node
  projectId   String   // direct link to project for project-level attachments
  fileName    String
  originalName String
  fileUrl     String
  fileSize    Int
  mimeType    String
  storageType String   @default("LOCAL") // LOCAL, API
  uploadedById String?
  createdAt   DateTime @default(now())

  node     VaultNode? @relation(fields: [nodeId], references: [id], onDelete: Cascade)
  project  Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploader User?      @relation(fields: [uploadedById], references: [id])

  @@map("vault_attachments")
}
