  eventKey          String   @unique
  name              String
  description       String?
  channels          String   @default("[\"IN_APP\",\"EMAIL\"]") // JSON array: IN_APP, EMAIL
  recipientStrategy String   @default("ASSIGNEE") // ASSIGNEE, ASSIGNED_ROLE, SPECIFIC_USERS, ALL_ADMINS, CREATOR
  isActive          Boolean  @default(true)
